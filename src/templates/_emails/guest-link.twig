{% apply spaceless %}
<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"></head>
<body style="margin:0; padding:0; background:#f4f4f7; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; color:#1f2933;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7; padding:24px 0;">
        <tr><td align="center">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px; background:#fff; border-radius:10px;">
                <tr><td style="padding:24px 28px;">
                    <p style="margin:0 0 16px; font-size:15px; line-height:1.5;">
                        {{ 'Thanks for getting in touch — we’ve received your message “{subject}” and will reply by email.'|t('pigeon', { subject: thread.title }) }}
                    </p>
                    <p style="margin:0 0 20px; font-size:15px; line-height:1.5;">
                        {{ 'You can view the conversation and add replies anytime using your private link:'|t('pigeon') }}
                    </p>
                    <a href="{{ link }}" style="display:inline-block; background:#2f6f4f; color:#fff; text-decoration:none; padding:11px 22px; border-radius:6px; font-size:15px; font-weight:600;">{{ 'View conversation'|t('pigeon') }}</a>
                    <p style="margin:18px 0 0; font-size:12px; color:#9aa5b1; word-break:break-all;">{{ link }}</p>
                </td></tr>
            </table>
        </td></tr>
    </table>
</body>
</html>
{% endapply %}
